;; 09-stdlib-math.lisp — (require "math")

(require "math")

(abs -42)          ;; => 42
(min 3 7)          ;; => 3
(max 3 7)          ;; => 7
(even? 4)          ;; => true
(odd? 7)           ;; => true
(gcd 12 8)         ;; => 4
(lcm 4 6)          ;; => 12
(square 5)         ;; => 25
(pow 2 10)         ;; => 1024
(sqrt 144)         ;; => 12
(identity 42)      ;; => 42
